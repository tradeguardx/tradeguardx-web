# Supabase (must match the backend / JWT for the API environment you use)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- API target: same rule for user, subscription, payments, trades ---
# Set VITE_APP_ENV to: prod | dev | local
# - prod → https://api.tradeguardx.com/{user|subscription|payments|trades}
# - dev  → https://dev.api.tradeguardx.com/...
# - local → localhost ports (3000 user, 3001 subscription, 3002 payments, 3009 trades)
# If VITE_APP_ENV is omitted, defaults to prod.
VITE_APP_ENV=prod

# Optional: override ONE service only (full base including path segment, no trailing slash)
# Example — payments only to dev while rest stay on prod (unusual; prefer one VITE_APP_ENV):
# VITE_PAYMENTS_API_BASE_URL=https://dev.api.tradeguardx.com/payments
# VITE_API_BASE_URL=https://api.tradeguardx.com/user
# VITE_SUBSCRIPTION_API_BASE_URL=https://api.tradeguardx.com/subscription
# VITE_TRADE_API_BASE_URL=https://api.tradeguardx.com/trades

# Beta registration at /beta-traders — POST to Formspree (or similar). Required for form submit button.
# VITE_BETA_SIGNUP_ENDPOINT=https://formspree.io/f/your-form-id

# --- Sentry error tracking (optional) ---
# When VITE_SENTRY_DSN is unset, Sentry init is a no-op and nothing is reported.
# Create a project at https://sentry.io → settings → projects → "tradeguardx-web"
# → Client Keys (DSN) and paste it here. The release tag below buckets errors
# per deploy (set to your CI commit SHA or version string in production).
# VITE_SENTRY_DSN=https://abc123@o0.ingest.sentry.io/000000
# VITE_APP_VERSION=0.0.1
