# One of: local | dev | prod. `dev` uses hosted https://dev.api.tradeguardx.com for user, subscription, payments, trades.
# Use `local` only with serverless-offline (ports 3000, 3001, 3002, 3009).
VITE_APP_ENV=dev
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Beta registration at /beta-traders — POST to Formspree (or similar). Required for form submit button.
# VITE_BETA_SIGNUP_ENDPOINT=https://formspree.io/f/your-form-id

# Optional per-service overrides (omit to use VITE_APP_ENV defaults from src/api/config.js).
# VITE_API_BASE_URL=https://dev.api.tradeguardx.com/user
# VITE_SUBSCRIPTION_API_BASE_URL=https://dev.api.tradeguardx.com/subscription
# VITE_PAYMENTS_API_BASE_URL=https://dev.api.tradeguardx.com/payments
# Trade service only — e.g. local serverless-offline on port 3009 while other APIs stay on dev:
# VITE_TRADE_API_BASE_URL=http://localhost:3009
